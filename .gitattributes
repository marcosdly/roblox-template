###############################################################################
# Core normalization
###############################################################################
* text=auto eol=lf

# Windows-specific scripts
*.bat text eol=crlf
*.ps1 text eol=crlf

###############################################################################
# Roblox / Rojo / Pesde source files
###############################################################################
# Lua / Luau
*.lua text diff=lua
*.luau text diff=lua

# JSON-based project configs
*.json text diff=json
*.project.json text diff=json
*.model.json text diff=json

# XML-based Roblox formats (rbxmx, etc.)
*.rbxmx text diff=xml
*.rbxlx text diff=xml

# TOML (Pesde, tooling configs)
*.toml text diff

# YAML (CI, tooling)
*.yml text
*.yaml text

###############################################################################
# Locking / merge strategies for critical structured files
###############################################################################
# Avoid bad merges on project definition files
default.project.json merge=union
*.project.json merge=union

# Lock files should not be merged
*.lock merge=binary
pesde.lock merge=binary

###############################################################################
# Binary Roblox formats (NEVER text)
###############################################################################
*.rbxl binary
*.rbxm binary

###############################################################################
# Git LFS tracking (large assets)
###############################################################################
# Images
*.png filter=lfs diff=lfs merge=lfs -text
*.jpg filter=lfs diff=lfs merge=lfs -text
*.jpeg filter=lfs diff=lfs merge=lfs -text
*.tga filter=lfs diff=lfs merge=lfs -text
*.psd filter=lfs diff=lfs merge=lfs -text

# Audio
*.mp3 filter=lfs diff=lfs merge=lfs -text
*.ogg filter=lfs diff=lfs merge=lfs -text
*.wav filter=lfs diff=lfs merge=lfs -text
*.flac filter=lfs diff=lfs merge=lfs -text

# Video
*.mp4 filter=lfs diff=lfs merge=lfs -text
*.mov filter=lfs diff=lfs merge=lfs -text

# 3D / meshes
*.fbx filter=lfs diff=lfs merge=lfs -text
*.obj filter=lfs diff=lfs merge=lfs -text
*.blend filter=lfs diff=lfs merge=lfs -text

# Fonts
*.ttf filter=lfs diff=lfs merge=lfs -text
*.otf filter=lfs diff=lfs merge=lfs -text

###############################################################################
# Archives & large blobs
###############################################################################
*.zip filter=lfs diff=lfs merge=lfs -text
*.7z filter=lfs diff=lfs merge=lfs -text
*.rar filter=lfs diff=lfs merge=lfs -text

###############################################################################
# Build outputs / generated files
###############################################################################
# Minified or compiled Lua (if you generate them)
*.min.lua -diff

# Logs
*.log text

###############################################################################
# Diff drivers (optional but useful)
###############################################################################
# Better Lua diffs (if configured in git config)
*.lua diff=lua
*.luau diff=lua

###############################################################################
# Safety rules
###############################################################################
# Never attempt text conversion on unknown binaries
*.bin binary
*.dat binary